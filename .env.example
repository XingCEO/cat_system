# TWSE Stock Filter - Environment Configuration
# Copy this file to .env and customize as needed

# ──────────────────────────── Core ────────────────────────────

# FinMind API Token (optional, increases request quota)
FINMIND_API_TOKEN=

# Database URL (default: SQLite for local dev)
DATABASE_URL=sqlite+aiosqlite:///./twse_filter.db

# Docker Compose Postgres settings (used by docker-compose.yml)
POSTGRES_DB=meow_stock
POSTGRES_USER=meow
POSTGRES_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD

# Cache expiration (seconds)
CACHE_EXPIRE_SECONDS=300

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Debug mode
DEBUG=false

# ─────────────────────── Admin / auth gate ───────────────────────

# Bearer token required for /api/cache/clear, /api/data/refresh,
# /api/v1/sync, and /api/v1/strategies/* CRUD. Leave empty to keep those
# endpoints disabled (they will return 503) when REQUIRE_ADMIN_TOKEN=true.
ADMIN_TOKEN=
# Set to false in local dev to bypass the gate entirely.
REQUIRE_ADMIN_TOKEN=true

# ─────────────────────── TWSE SSL workaround ───────────────────────

# Python 3.14 enforces X509 strict validation. TWSE certs miss the
# Subject Key Identifier extension, so set TWSE_SSL_MODE=relaxed if you
# see "CERTIFICATE_VERIFY_FAILED: Missing Subject Key Identifier".
#   default  — system/certifi bundle (recommended)
#   certifi  — force certifi bundle
#   relaxed  — accept missing Subject Key Identifier
#   insecure — disable verification (NOT for prod)
TWSE_SSL_MODE=default
# Optional custom CA bundle path; overrides TWSE_SSL_MODE when set.
TWSE_SSL_CA_BUNDLE=

# ─────────────────────── Backfill / sync tuning ───────────────────────

# `_backfill_indicators` fallback threshold (days in v1 DB).
# MA20/MA60 need >= 60 days of history.
BACKFILL_MIN_DAYS=60
# Max tickers fetched from legacy fetcher per backfill pass.
BACKFILL_BATCH_SIZE=200
# Parallel fetch cap when backfilling via Yahoo/TWSE fallback.
BACKFILL_CONCURRENCY=10
# Periodic refresh interval (seconds) during TSE trading hours.
PERIODIC_REFRESH_INTERVAL=1800

# ─────────────────────── Rate-limit cooldowns (seconds) ───────────────────────

COOLDOWN_CACHE_CLEAR=60
COOLDOWN_DATA_REFRESH=120
COOLDOWN_SYNC=300

# ─────────────────────── Screen API DoS protection ───────────────────────

MAX_RULES_PER_REQUEST=32
MAX_FORMULAS_PER_REQUEST=8
MAX_FORMULA_LENGTH=500
MAX_FORMULA_TOKENS=50
